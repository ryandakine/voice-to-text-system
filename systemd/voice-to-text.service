[Unit]
Description=Voice-to-Text (Push-to-Talk)
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=@REPO_DIR@
ExecStart=@REPO_DIR@/.venv/bin/python @REPO_DIR@/start_push_to_talk.py
Restart=on-failure
RestartSec=2

# Required for X11-based global key listening and text insertion.
# If your DISPLAY is not :0, change this (or override via a drop-in).
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority

[Install]
WantedBy=default.target
